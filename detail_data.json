    "required_qualifications": {
      "ru": "",
      "en": "<ul>\n\t<li>At least 5 years of software development experience </li>\n\t<li>Experience working in frontend-focused teams </li>\n\t<li>Experience in component-based development </li>\n\t<li>Extensive knowledge of JavaScript (JS) and TypeScript (TS) along with one of the following – Angular/React </li>\n\t<li>Proficiency in writing automated tests </li>\n\t<li>Ability to work with existing codebases </li>\n</ul>\n\n<p> </p>\n",
      "am": ""
